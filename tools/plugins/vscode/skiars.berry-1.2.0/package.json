{
    "name": "berry",
    "displayName": "Berry Script Language",
    "description": "A small embedded script language.",
    "version": "1.2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/r-buc/berry.git"
    },
    "icon": "berry-icon.png",
    "publisher": "skiars",
    "main": "./extension.js",
    "engines": {
        "vscode": "^1.74.0"
    },
    "activationEvents": [
        "onLanguage:berry"
    ],
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "berry",
                "aliases": [
                    "Berry",
                    "berry"
                ],
                "extensions": [
                    ".be"
                ],
                "configuration": "./berry-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "berry",
                "scopeName": "source.berry",
                "path": "./syntaxes/berry.json"
            }
        ],
        "configurationDefaults": {
            "[berry]": {
                "editor.semanticHighlighting.enabled": true
            }
        }
    },
    "__metadata": null
}